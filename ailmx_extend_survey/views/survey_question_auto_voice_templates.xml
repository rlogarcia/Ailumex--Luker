<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="survey_question_auto_voice_inject"
              name="AILUMEX Auto Voice - Inyección en pregunta"
              inherit_id="survey.question_container">

        <xpath expr="." position="inside">

            <t t-if="question and question.flg_auto_voice_record">
                <div class="mt-3 ailmx_auto_voice_wrapper"
                     t-att-data-question-id="question.id"
                     t-att-data-record-mode="question.modo_grabacion_voz or 'auto'">

                    <div class="ailmx_auto_voice_header">
                        <span class="ailmx_auto_voice_dot"></span>
                        <span class="ailmx_auto_voice_title">
                            <t t-if="(question.modo_grabacion_voz or 'auto') == 'auto'">
                                Grabación automática activa
                            </t>
                            <t t-else="">
                                Grabación manual disponible
                            </t>
                        </span>
                    </div>

                    <div class="ailmx_auto_voice_meta">
                        <span class="ailmx_auto_voice_timer">0:00</span>
                        <span class="ailmx_auto_voice_status">
                            <t t-if="(question.modo_grabacion_voz or 'auto') == 'auto'">
                                Preparando grabación...
                            </t>
                            <t t-else="">
                                Presiona grabar para iniciar.
                            </t>
                        </span>
                    </div>

                    <t t-if="(question.modo_grabacion_voz or 'auto') == 'manual'">
                        <div class="ailmx_auto_voice_controls">
                            <button type="button" class="ailmx_auto_voice_btn_record">
                                <span class="ailmx_auto_voice_btn_dot"></span>
                                Grabar
                            </button>

                            <button type="button" class="ailmx_auto_voice_btn_stop" style="display:none;">
                                ⏹ Detener
                            </button>

                            <button type="button" class="ailmx_auto_voice_btn_play" style="display:none;">
                                ▶ Reproducir
                            </button>

                            <button type="button" class="ailmx_auto_voice_btn_delete" style="display:none;">
                                🗑 Eliminar
                            </button>
                        </div>
                    </t>

                    <div class="ailmx_auto_voice_wave">
                        <span></span><span></span><span></span><span></span>
                        <span></span><span></span><span></span><span></span>
                    </div>

                    <audio class="ailmx_auto_voice_playback" style="display:none;"></audio>
                </div>
            </t>

        </xpath>

    </template>

</odoo>