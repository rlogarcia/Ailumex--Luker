<?xml version="1.0" encoding="utf-8"?>

<!--
    Este archivo extiende la vista del formulario de preguntas (survey.survey_question_form).
    No reemplaza la vista original de Odoo, sino que "inyecta" nuevos campos 
    en lugares específicos usando XPath.
-->

<odoo>
    <record id="view_survey_question_extension_form" model="ir.ui.view">
        <field name="name">survey.question.extension.form</field>
        <field name="model">survey.question</field>

        <!-- Apunta a la vista original de preguntas de Odoo -->
        <field name="inherit_id" ref="survey.survey_question_form"/> 
        
        <field name="arch" type="xml">

            <!-- 
                CONFIGURACIÓN DE TIEMPO (TIMER)
                Se coloca a la derecha del selector de "Tipo de pregunta".
                Se busca el grupo que contiene 'question_type' y y se utiliza position="after"
                para crear una segunda columna a la derecha.
            -->
            <xpath expr="//group[field[@name='question_type']]" position="after">
                
                <group string="Temporizador de preguntas." name="timer_settings">
                    <!-- Checkbox para activar la funcionalidad -->
                    <field name="has_time_limit" string="¿Activar temporizador?"/>
                    
                    <!-- 
                        CAMPOS CONDICIONALES:
                        En Odoo 18 se usa invisible="not campo" directamente.
                        - widget="radio" con options horizontal hace que se vea moderno.
                    -->
                    <field name="time_limit_unit" 
                        string="Unidad"
                        widget="radio" 
                        options="{'horizontal': true}"
                        invisible="not has_time_limit"/>
                    
                    <field name="time_limit_value"
                        string="Cantidad"
                        invisible="not has_time_limit"
                        placeholder="ej. 30"/>
                </group>

            </xpath>

            <!-- 
                CONFIGURACIÓN AILUMEX
                Este inserta los campos de gobernanza al final del formulario.
            -->
            <xpath expr="//form" position="inside">
            
                <!-- Sección nueva con los campos de la extensión -->
                <group string="Configuración AiLumex">

                    <!-- FK al catálogo de tipos de pregunta -->
                    <field
                        name="Id_Question_Type"
                        string="Tipo de Pregunta"/>

                    <!-- Configuración específica en JSON -->
                    <field
                        name="Des_Config_JSON"
                        string="Configuración JSON"/>

                    <!-- Si la pregunta es obligatoria -->
                    <field
                        name="Flg_Required"
                        string="Es obligatoria"/>

                    <!-- FK al elemento DAMA -->
                    <field
                        name="Id_Data_Element"
                        string="Elemento de dato DAMA"/>                 
                </group>
            </xpath>
        </field>
    </record>
</odoo>