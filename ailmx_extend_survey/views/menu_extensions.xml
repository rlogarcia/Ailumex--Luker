<?xml version="1.0" encoding="utf-8"?>

<!-- Archivo para crear menús nuevos de instrumentos, participantes y aplicaciones -->

<odoo>

    <!-- ========================================================= -->
    <!-- ACCIONES -->
    <!-- ========================================================= -->

    <record id="action_maestro_participantes" model="ir.actions.act_window">
        <field name="name">Maestro participantes</field>
        <field name="res_model">ailmx.participant</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_contexto_organizacional" model="ir.actions.act_window">
        <field name="name">Contexto organizacional</field>
        <field name="res_model">survey.user_input</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_atributos_dinamicos" model="ir.actions.act_window">
        <field name="name">Atributos dinámicos</field>
        <field name="res_model">survey.user_input</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ========================================================= -->
    <!-- MENÚS PRINCIPALES NUEVOS DENTRO DE LA APP ENCUESTAS -->
    <!-- ========================================================= -->

    <menuitem
        id="menu_ailmx_instrumentos_root"
        name="Instrumentos"
        parent="survey.menu_surveys"
        action="survey.action_survey_form"
        sequence="5"/>

    <menuitem
        id="menu_ailmx_participantes_root"
        name="Participantes"
        parent="survey.menu_surveys"
        sequence="10"/>

    <menuitem
        id="menu_ailmx_aplicaciones_root"
        name="Aplicaciones"
        parent="survey.menu_surveys"
        action="action_survey_application"
        sequence="15"/>

    <!-- ========================================================= -->
    <!-- SUBMENÚS DE PARTICIPANTES -->
    <!-- ========================================================= -->

    <menuitem
        id="menu_maestro_participantes"
        name="Maestro participantes"
        parent="menu_ailmx_participantes_root"
        action="action_maestro_participantes"
        sequence="10"/>

    <menuitem
        id="menu_contexto_organizacional"
        name="Contexto organizacional"
        parent="menu_ailmx_participantes_root"
        action="action_contexto_organizacional"
        sequence="20"/>

    <menuitem
        id="menu_atributos_dinamicos"
        name="Atributos dinámicos"
        parent="menu_ailmx_participantes_root"
        action="action_atributos_dinamicos"
        sequence="30"/>

</odoo>