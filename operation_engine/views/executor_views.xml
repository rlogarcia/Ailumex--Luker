<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_luker_executor_list" model="ir.ui.view">
        <field name="name">luker.operation.executor.list</field>
        <field name="model">luker.operation.executor</field>
        <field name="arch" type="xml">
            <list string="Ejecutores SISPAR"
                  decoration-danger="not activo">
                <field name="cod_ejecutor"   string="Código"/>
                <field name="image_128"      widget="image" string=" " width="28"/>
                <field name="nom_ejecutor"   string="Nombre"/>
                <field name="rol" widget="badge"
                       decoration-info="rol == 'aplicador'"
                       decoration-warning="rol == 'supervisor'"
                       decoration-success="rol == 'coordinador'"/>
                <field name="job_title"      string="Cargo" optional="show"/>
                <field name="work_email"     string="Correo" optional="show"/>
                <field name="work_phone"     string="Teléfono" optional="show"/>
                <field name="tarea_count"          string="Tareas"/>
                <field name="tarea_completada_count" string="Completadas"/>
                <field name="activo"         widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_luker_executor_form" model="ir.ui.view">
        <field name="name">luker.operation.executor.form</field>
        <field name="model">luker.operation.executor</field>
        <field name="arch" type="xml">
            <form string="Ejecutor SISPAR">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_tareas"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-tasks"
                                invisible="tarea_count == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="tarea_completada_count"/>/<field name="tarea_count"/>
                                </span>
                                <span class="o_stat_text">Tareas</span>
                            </div>
                        </button>
                        <button name="action_abrir_empleado"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-id-card">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Ver empleado</span>
                            </div>
                        </button>
                    </div>

                    <!-- Foto del empleado -->
                    <field name="image_128" widget="image"
                           class="oe_avatar" readonly="1"/>

                    <div class="oe_title">
                        <label for="employee_id" string="Empleado"/>
                        <h1>
                            <field name="employee_id"
                                   placeholder="Selecciona el empleado..."
                                   options="{'no_create': True}"/>
                        </h1>
                    </div>

                    <!-- Datos del empleado (readonly — se editan en RRHH) -->
                    <div class="alert alert-secondary d-flex gap-2 mb-3"
                         invisible="not employee_id">
                        <i class="fa fa-info-circle mt-1"/>
                        <span>Los datos personales se gestionan en
                            <strong>Empleados</strong>.
                            Aquí solo defines el rol SISPAR y las instituciones asignadas.
                        </span>
                    </div>

                    <group>
                        <group string="Datos del empleado (solo lectura)">
                            <field name="cod_ejecutor"       readonly="1"/>
                            <field name="num_identificacion" readonly="1"/>
                            <field name="job_title"          readonly="1"/>
                            <field name="department_id"      readonly="1"/>
                            <field name="work_email"         readonly="1"/>
                            <field name="work_phone"         readonly="1"/>
                            <field name="mobile_phone"       readonly="1"/>
                            <field name="user_id"            readonly="1"/>
                        </group>
                        <group string="Rol SISPAR">
                            <field name="rol"/>
                            <field name="activo"/>
                        </group>
                    </group>

                    <group string="Cobertura operativa">
                        <field name="institucion_ids"
                               widget="many2many_tags"
                               nolabel="1"
                               placeholder="Selecciona las instituciones donde opera"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_luker_executor" model="ir.actions.act_window">
        <field name="name">Ejecutores SISPAR</field>
        <field name="res_model">luker.operation.executor</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_activo': 1}</field>
    </record>

</odoo>
