<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_survey_question_section_display_option" model="ir.ui.view">
        <field name="name">AILUMEX - Mostrar info de sección</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="survey.survey_question_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='is_page']" position="after">

                <div class="mt-2 mb-3" invisible="not is_page">
                    <div class="o_form_label">
                        Mostrar información de la sección
                    </div>

                    <div class="text-muted mb-1" style="font-size: 12px;">
                        Si activas esta opción, el título y la descripción de esta sección se mostrarán encima de cada pregunta.
                    </div>

                    <field name="mostrar_info_seccion"
                            nolabel="1"/>
                </div>

            </xpath>

        </field>
    </record>

</odoo>