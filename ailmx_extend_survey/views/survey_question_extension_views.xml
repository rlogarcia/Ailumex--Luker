<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_survey_question_extension_form" model="ir.ui.view">
        <field name="name">survey.question.extension.form</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="survey.survey_question_form"/>
        <field name="arch" type="xml">

            <!-- TEMPORIZADOR -->
            <xpath expr="//group[field[@name='question_type']]" position="after">
                <group string="Temporizador de preguntas" name="timer_settings">
                    <field name="has_time_limit" string="¿Activar temporizador?"/>
                    <field name="time_limit_unit"
                            string="Unidad"
                            widget="radio"
                            options="{'horizontal': true}"
                            invisible="not has_time_limit"/>
                    <field name="time_limit_value"
                            string="Cantidad"
                            invisible="not has_time_limit"
                            placeholder="Ej. 30"/>
                </group>
            </xpath>

            <!-- ADJUNTAR IMÁGENES -->
            <xpath expr="//group[field[@name='question_type']]" position="after">
                <group string="Adjuntar imagen" name="image_attachment_settings">
                    <field name="Flg_Allow_Image_Attachment"
                            string="¿Permitir adjuntar imagen?"/>

                    <field name="Question_Image_Attachment_Ids"
                            string="Imágenes"
                            widget="many2many_binary"
                            invisible="not Flg_Allow_Image_Attachment"/>

                    <field name="Img_Question_Attachment"
                            string="Imagen única (compatibilidad)"
                            widget="image"
                            invisible="1"/>
                </group>
            </xpath>

            <!-- CONFIGURACIÓN AILUMEX -->
            <xpath expr="//form" position="inside">
                <group string="Configuración AiLumex">
                    <field name="Id_Question_Type" string="Tipo de Pregunta"/>
                    <field name="Des_Config_JSON" string="Configuración JSON"/>
                    <field name="Flg_Required" string="Es obligatoria"/>
                    <field name="Id_Data_Element" string="Elemento de dato DAMA"/>
                </group>
            </xpath>

            <!-- RESPUESTA CORRECTA -->
            <xpath expr="//field[@name='suggested_answer_ids']/list/field[last()]" position="after">
                <field name="Flg_Is_Correct" string="Es correcta"/>
            </xpath>

        </field>
    </record>
</odoo>