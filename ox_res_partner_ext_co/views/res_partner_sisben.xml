<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree view -->
        <record id="res_partner_sisben_view_tree" model="ir.ui.view">
            <field name="name">res.partner.sisben.tree</field>
            <field name="model">res.partner.sisben</field>
            <field name="arch" type="xml">
                <list string="Clasificaciones SISBEN" editable="bottom">
                    <field name="codigo" />
                    <field name="grupo" />
                    <field name="descripcion" />
                    <field name="nivel_vulnerabilidad" />
                    <field name="aplica_subsidio" />
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="res_partner_sisben_view_form" model="ir.ui.view">
            <field name="name">res.partner.sisben.form</field>
            <field name="model">res.partner.sisben</field>
            <field name="arch" type="xml">
                <form string="Clasificación SISBEN">
                    <sheet>
                        <group>
                            <group>
                                <field name="codigo" />
                                <field name="grupo" />
                                <field name="descripcion" />
                            </group>
                            <group>
                                <field name="nivel_vulnerabilidad" />
                                <field name="aplica_subsidio" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="res_partner_sisben_action" model="ir.actions.act_window">
            <field name="name">Clasificaciones SISBEN</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.partner.sisben</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
