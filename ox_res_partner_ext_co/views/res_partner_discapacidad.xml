<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Tree view -->
        <record id="res_partner_discapacidad_view_tree" model="ir.ui.view">
            <field name="name">res.partner.discapacidad.tree</field>
            <field name="model">res.partner.discapacidad</field>
            <field name="arch" type="xml">
                <list string="Tipos de Discapacidad" editable="bottom">
                    <field name="codigo" />
                    <field name="tipo" />
                    <field name="name" string="Nombre" />
                </list>
            </field>
        </record>

        <!-- Form view -->
        <record id="res_partner_discapacidad_view_form" model="ir.ui.view">
            <field name="name">res.partner.discapacidad.form</field>
            <field name="model">res.partner.discapacidad</field>
            <field name="arch" type="xml">
                <form string="Tipo de Discapacidad">
                    <sheet>
                        <group>
                            <group>
                                <field name="codigo" />
                                <field name="tipo" />
                            </group>
                            <group>
                                <field name="name" string="Nombre" />
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action -->
        <record id="res_partner_discapacidad_action" model="ir.actions.act_window">
            <field name="name">Tipos de Discapacidad</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.partner.discapacidad</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
