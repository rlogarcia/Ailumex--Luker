<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ailmx_extend_survey.MathGridWizardWidget">
        <div class="ailmx_math_wizard_wrapper">

            <div class="ailmx_math_mode_selector">
                <button type="button"
                        class="ailmx_mode_btn"
                        t-att-class="state.editMode === 'value' ? 'ailmx_mode_btn ailmx_mode_active' : 'ailmx_mode_btn'"
                        t-on-click="() => this.setEditMode('value')">
                    Contenido visible
                </button>

                <button type="button"
                        class="ailmx_mode_btn"
                        t-att-class="state.editMode === 'correct' ? 'ailmx_mode_btn ailmx_mode_active' : 'ailmx_mode_btn'"
                        t-on-click="() => this.setEditMode('correct')">
                    Valor correcto
                </button>
            </div>

            <div class="ailmx_math_mode_hint">
                <t t-if="state.editMode === 'value'">
                    Editando el contenido que verá el participante.
                </t>
                <t t-else="">
                    Editando la respuesta correcta usada para evaluación.
                </t>
            </div>

            <table class="ailmx_wizard_grid_table ailmx_math_grid_table">
                <tbody>
                    <t t-foreach="state.grid" t-as="row" t-key="row[0].rowIndex">
                        <tr>
                            <t t-foreach="row" t-as="cell" t-key="cell.rowIndex + '_' + cell.colIndex">
                                <td class="ailmx_wizard_grid_td">
                                    <input
                                        type="text"
                                        class="ailmx_wizard_cell_input"
                                        t-att-class="state.editMode === 'correct' ? 'ailmx_wizard_cell_input ailmx_cell_correct_mode' : 'ailmx_wizard_cell_input'"
                                        t-att-id="'ailmx_math_' + state.editMode + '_' + cell.rowIndex + '_' + cell.colIndex"
                                        t-att-placeholder="state.editMode === 'value' ? 'Visible' : 'Correcto'"
                                        t-att-value="state.editMode === 'value' ? cell.cell_value : cell.correct_value"
                                        t-on-input="(ev) => this.onInput(cell.rowIndex, cell.colIndex, state.editMode === 'value' ? 'cell_value' : 'correct_value', ev.target.value)"
                                        t-on-keydown="(ev) => this.onKeyDown(ev, cell.rowIndex, cell.colIndex)"
                                    />
                                </td>
                            </t>
                        </tr>
                    </t>
                </tbody>
            </table>

            <t t-if="state.showCommaModal">
                <div class="ailmx_comma_modal_backdrop">
                    <div class="ailmx_comma_modal">

                        <div class="ailmx_comma_modal_header">
                            <div class="ailmx_comma_modal_title">
                                Importar grid separado por comas
                            </div>
                        </div>

                        <div class="ailmx_comma_modal_body">

                            <label class="ailmx_comma_label">
                                Contenido visible:
                            </label>

                            <textarea
                                class="ailmx_comma_textarea"
                                t-att-value="state.commaVisibleInput"
                                t-on-input="onCommaVisibleInput"
                                placeholder="2+2, 5+3, 1+22, 12+7..."
                            />

                            <label class="ailmx_comma_label">
                                Valor correcto:
                            </label>

                            <textarea
                                class="ailmx_comma_textarea"
                                t-att-value="state.commaCorrectInput"
                                t-on-input="onCommaCorrectInput"
                                placeholder="4, 8, 23, 19..."
                            />

                            <label class="ailmx_comma_label">
                                Vista previa:
                            </label>

                            <div class="ailmx_comma_preview_wrapper ailmx_math_preview_wrapper">
                                <table class="ailmx_comma_preview_table ailmx_math_preview_table">
                                    <tbody>
                                        <t t-foreach="state.previewGrid" t-as="row" t-key="row.rowKey">
                                            <tr>
                                                <t t-foreach="row.cells" t-as="cell" t-key="cell.cellKey">
                                                    <td class="ailmx_comma_preview_cell ailmx_math_preview_cell">
                                                        <div>
                                                            <t t-esc="cell.visible"/>
                                                        </div>
                                                        <t t-if="cell.correct">
                                                            <div class="ailmx_comma_preview_subvalue">
                                                                = <t t-esc="cell.correct"/>
                                                            </div>
                                                        </t>
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>

                        </div>

                        <div class="ailmx_comma_modal_footer">
                            <button type="button"
                                    class="btn btn-secondary"
                                    t-on-click="closeCommaImportModal">
                                Cancelar
                            </button>

                            <button type="button"
                                    class="btn btn-success"
                                    t-on-click="applyCommaImport">
                                Guardar
                            </button>
                        </div>

                    </div>
                </div>
            </t>

        </div>
    </t>

</templates>