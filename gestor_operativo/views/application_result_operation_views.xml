<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_application_result_operation_inherit" model="ir.ui.view">
        <field name="name">luker.application.result.form.operation.inherit</field>
        <field name="model">luker.application.result</field>
        <field name="inherit_id" ref="gestor_operativo.view_luker_application_result_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Contexto operativo" name="operativo">
                    <group>
                        <group string="Campaña y tarea">
                            <field name="campana_id" readonly="1"/>
                            <field name="task_id" readonly="1"/>
                            <field name="executor_id" readonly="1"/>
                        </group>
                        <group string="Offline / Sync">
                            <field name="uuid_local" readonly="1"/>
                            <field name="sync_status" widget="badge"
                                   decoration-success="sync_status == 'synced'"
                                   decoration-warning="sync_status in ('queued','draft')"
                                   decoration-danger="sync_status in ('conflict','error')"/>
                            <field name="dispositivo_id" readonly="1"/>
                            <field name="fecha_inicio_dispositivo" readonly="1"/>
                            <field name="fecha_fin_dispositivo" readonly="1"/>
                        </group>
                    </group>
                    <group string="Estado de captura">
                        <field name="estado_sesion" widget="statusbar"
                               statusbar_visible="iniciada,en_pausa,completada"/>
                        <field name="pregunta_actual" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
