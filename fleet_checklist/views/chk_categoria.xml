<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== CATEGORÍAS ==================== -->

    <!-- List View -->
    <record id="chk_categoria_view_list" model="ir.ui.view">
        <field name="name">chk.categoria.view.list</field>
        <field name="model">chk.categoria</field>
        <field name="arch" type="xml">
            <list string="Categorías">
                <field name="secuencia" widget="handle"/>
                <field name="nom_categoria"/>
                <field name="activo"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="chk_categoria_view_form" model="ir.ui.view">
        <field name="name">chk.categoria.view.form</field>
        <field name="model">chk.categoria</field>
        <field name="arch" type="xml">
            <form string="Categoría">
                <sheet>
                    <group>
                        <group string="Información">
                            <field name="nom_categoria"/>
                            <field name="secuencia"/>
                            <field name="activo"/>
                        </group>
                        <group string="Auditoría">
                            <field name="fecha_creacion" readonly="1"/>
                            <field name="fecha_actualizacion" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="chk_categoria_action" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">chk.categoria</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
