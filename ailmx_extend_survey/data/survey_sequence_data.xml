<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Define la secuencia automática para instrumentos.
            Cada vez que se crea un instrumento nuevo,
            Odoo llama a esta secuencia y genera el siguiente código.

            prefix: texto que va al inicio (INS-)
            padding: cuántos dígitos tiene el número (4 = 0001)
        -->
        <record id="sequence_survey_instrument" model="ir.sequence">
            <field name="name">Secuencia de Instrumentos</field>
            <field name="code">survey.survey.instrument</field>
            <field name="prefix">INS-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next_actual">1</field>
        </record>

    </data>
</odoo>