<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="survey_question_math_grid_inject"
              name="AILUMEX - GRID matemático"
              inherit_id="survey.question_container">
        <xpath expr="." position="inside">
            <t t-if="question and question.question_type == 'math_grid'">
                <div class="mt-3 ailmx_math_grid_wrapper"
                     t-att-data-question-id="question.id">
                    <table class="table table-bordered text-center ailmx_math_grid_table">
                        <tbody>
                            <t t-foreach="range(question.math_grid_rows)" t-as="row_index">
                                <tr>
                                    <t t-foreach="range(question.math_grid_cols)" t-as="col_index">
                                        <t t-set="cell_record"
                                           t-value="question.math_grid_cell_ids.filtered(lambda c: c.row_index == row_index and c.col_index == col_index)[:1]"/>
                                        <td class="ailmx_math_grid_cell"
                                            t-att-data-row="row_index"
                                            t-att-data-col="col_index">
                                            <input type="text"
                                                   class="form-control ailmx_math_grid_input"
                                                   t-att-placeholder="cell_record.cell_value if cell_record else ''"
                                                   t-att-data-correct="cell_record.correct_value if cell_record else ''"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <input type="hidden"
                           t-attf-name="question_#{question.id}"
                           class="ailmx_math_grid_response"/>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
