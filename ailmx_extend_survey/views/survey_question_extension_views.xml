<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_survey_question_extension_form" model="ir.ui.view">
        <field name="name">survey.question.extension.form</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="survey.survey_question_form"/>
        <field name="arch" type="xml">

            <!-- TEMPORIZADOR -->
            <xpath expr="//group[field[@name='question_type']]" position="after">
                <group string="Temporizador de preguntas" name="timer_settings">
                    <field name="flg_time_limit" string="¿Activar temporizador?"/>
                    <field name="unidad_limite_tiempo"
                           string="Unidad"
                           widget="radio"
                           options="{'horizontal': true}"
                           invisible="not flg_time_limit"/>
                    <field name="valor_limite_tiempo"
                           string="Cantidad"
                           invisible="not flg_time_limit"
                           placeholder="Ej. 30"/>
                </group>
            </xpath>

            <!-- ADJUNTAR IMÁGENES -->
            <xpath expr="//group[field[@name='question_type']]" position="after">
                <group string="Adjuntar imagen" name="image_attachment_settings">
                    <field name="flg_allow_image_attachment"
                           string="¿Permitir adjuntar imagen?"/>

                    <field name="question_image_attachment_ids"
                           string="Imágenes"
                           widget="many2many_binary"
                           invisible="not flg_allow_image_attachment"/>

                    <field name="img_question_attachment"
                           string="Imagen única (compatibilidad)"
                           widget="image"
                           invisible="1"/>
                </group>
            </xpath>

            <!-- GRABACIÓN DE VOZ -->
            <xpath expr="//group[field[@name='question_type']]" position="after">
                <group string="Grabación de voz" name="voice_record_settings">
                    <field name="flg_auto_voice_record" string="¿Grabar voz?"/>
                    <field name="modo_grabacion_voz"
                           string="Modo de grabación"
                           widget="radio"
                           options="{'horizontal': true}"
                           invisible="not flg_auto_voice_record"/>
                </group>
            </xpath>

            <!-- CONFIGURACIÓN AILUMEX -->
            <xpath expr="//form" position="inside">
                <group string="Configuración AiLumex">
                    <field name="id_question_type" string="Tipo de Pregunta"/>
                    <field name="des_config_json" string="Configuración JSON"/>
                    <field name="flg_required" string="Es obligatoria"/>
                    <field name="id_luker_data_element" string="Elemento de dato DAMA"/>
                </group>
            </xpath>

            <!-- RESPUESTA CORRECTA -->
            <xpath expr="//field[@name='suggested_answer_ids']/list/field[last()]" position="after">
                <field name="flg_is_correct" string="Es correcta"/>
            </xpath>

            <!-- ========================================================= -->
            <!-- CONDICIONES DE FINALIZACIÓN -->
            <!-- ========================================================= -->
            <xpath expr="//notebook" position="inside">
                <page string="Condiciones de finalización" name="finish_conditions_page">

                    <div class="alert alert-warning" role="alert">
                        Define cuándo esta pregunta debe <strong>finalizar la encuesta</strong>
                        según la comparación con otra pregunta de la misma encuesta.
                    </div>

                    <!-- Campo auxiliar invisible para que el widget reciba las preguntas -->
                    <field name="condiciones_fin_opciones" invisible="1"/>

                    <!-- Editor custom -->
                    <field name="condiciones_fin_json" widget="finish_condition_editor"/>

                </page>
            </xpath>

        </field>
    </record>
</odoo>