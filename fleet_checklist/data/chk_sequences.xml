<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_chk_plantilla" model="ir.sequence">
        <field name="name">CHK Plantilla</field>
        <field name="code">chk.plantilla</field>
        <field name="prefix">PLT-</field>
        <field name="padding">4</field>
        <field name="number_increment">1</field>
        <field name="number_next">1</field>
