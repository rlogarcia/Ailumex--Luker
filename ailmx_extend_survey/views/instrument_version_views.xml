<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════════
         VISTAS DEL MODELO luker.instrument.version
         ══════════════════════════════════════════════════════════════════════ -->

    <!-- ── Formulario de versión ─────────────────────────────────────────── -->
    <record id="view_luker_instrument_version_form" model="ir.ui.view">
        <field name="name">luker.instrument.version.form</field>
        <field name="model">luker.instrument.version</field>
        <field name="arch" type="xml">
            <form string="Versión del instrumento">
                <header>
                    <button name="action_publicar" string="Publicar versión"
                            type="object" class="btn-success"
                            invisible="estado != 'borrador'"/>
                    <button name="action_deprecar" string="Deprecar"
                            type="object" class="btn-warning"
                            invisible="estado != 'publicada'"/>
                    <button name="action_nueva_version" string="Nueva versión desde esta"
                            type="object" invisible="estado == 'borrador'"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="borrador,publicada,deprecada"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="PUBLICADA"
                            bg_color="text-bg-success"
                            invisible="estado != 'publicada'"/>
                    <widget name="web_ribbon" title="DEPRECADA"
                            bg_color="text-bg-secondary"
                            invisible="estado != 'deprecada'"/>

                    <div class="oe_title">
                        <label for="nom_version" string="Nombre de la versión"/>
                        <h1>
                            <field name="nom_version"
                                   placeholder="Ej: SISPAR 2026 — Primer semestre"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Identificación">
                            <field name="cod_version" readonly="1"/>
                            <field name="survey_id" readonly="1"/>
                            <field name="anio"/>
                            <field name="num_version" readonly="1"/>
                            <field name="num_preguntas" readonly="1"/>
                            <field name="version_anterior_id" readonly="1"/>
                        </group>
                        <group string="Trazabilidad">
                            <field name="usuario_creacion_id" readonly="1"/>
                            <field name="fecha_creacion" readonly="1"/>
                            <field name="usuario_publicacion_id" readonly="1"
                                   invisible="not fecha_publicacion"/>
                            <field name="fecha_publicacion" readonly="1"
                                   invisible="not fecha_publicacion"/>
                            <field name="hash_contenido" readonly="1"
                                   invisible="not hash_contenido"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Preguntas de esta versión" name="preguntas">
                            <div class="alert alert-info mb-3">
                                <i class="fa fa-info-circle me-2"/>
                                Selecciona las preguntas que hacen parte de esta versión.
                                Las preguntas desmarcadas NO se aplicarán en campaña.
                                Total: <strong><field name="num_preguntas" readonly="1"/> pregunta(s) seleccionadas</strong>
                            </div>
                            <field name="question_ids" widget="many2many"
                                   options="{'no_create': True}">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="title" string="Pregunta"/>
                                    <field name="question_type" string="Tipo Odoo"/>
                                    <field name="id_question_type" string="Tipo custom"/>
                                    <field name="flg_required" string="Obligatoria"
                                           widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                        <page string="Registro de cambios" name="cambios">
                            <group>
                                <field name="descripcion_cambios"
                                       string="¿Qué cambió en esta versión?"
                                       placeholder="Ej: Se eliminaron las preguntas 3 y 7. Se ajustó el enunciado de la pregunta 12..."
                                       nolabel="1"/>
                            </group>
                        </page>
                        <page string="Notas internas" name="notas">
                            <group>
                                <field name="notas" nolabel="1"
                                       placeholder="Notas del equipo técnico, decisiones de diseño, comentarios del Comité DAMA..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Acción de ventana para versiones para versiones ──────────────────────────────── -->
    <record id="action_luker_instrument_version" model="ir.actions.act_window">
        <field name="name">Versiones de instrumentos</field>
        <field name="res_model">luker.instrument.version</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════════
         HERENCIA SOBRE survey.survey
         Agrega: botón smart "Versiones", botón "Versionar" en header
         y pestaña "Versiones" con historial completo
         ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_survey_form_version_inherit" model="ir.ui.view">
        <field name="name">survey.survey.form.version.inherit</field>
        <field name="model">survey.survey</field>
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <!-- Prioridad mayor que la vista base para que se aplique después -->
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- ── Smart button: Versiones ── -->
            <div name="button_box" position="inside">
                <button name="action_ver_versiones"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-code-fork"
                        invisible="num_versiones == 0">
                    <field name="num_versiones"
                           widget="statinfo"
                           string="Versiones"/>
                </button>
            </div>

            <!-- ── Botón "Versionar" en header ── -->
            <xpath expr="//form/header" position="inside">
                <button name="action_crear_version"
                        string="Versionar"
                        type="object"
                        class="btn-secondary"
                        icon="fa-code-fork"
                        invisible="instrument_state not in ('published', 'in_review')"/>
            </xpath>

            <!-- ── Reemplazar pestaña Versiones vacía con contenido completo ── -->
            <page name="versions" position="replace">
                <page string="Versiones" name="versions">

                    <!-- Última versión publicada -->
                    <group invisible="ultima_version_id == False">
                        <group string="Última versión publicada">
                            <field name="ultima_version_id" readonly="1"
                                   nolabel="1"/>
                        </group>
                    </group>

                    <!-- Historial completo -->
                    <field name="version_ids"
                           nolabel="1"
                           mode="list"
                           context="{'default_survey_id': id}">
                        <list string="Historial de versiones"
                              decoration-success="estado == 'publicada'"
                              decoration-warning="estado == 'borrador'">
                            <field name="cod_version" string="Código"/>
                            <field name="nom_version" string="Nombre de versión"/>
                            <field name="anio" string="Año"/>
                            <field name="num_version" string="Nº"/>
                            <field name="num_preguntas" string="Preguntas"/>
                            <field name="estado" widget="badge"
                                   decoration-success="estado == 'publicada'"
                                   decoration-warning="estado == 'borrador'"
                                   decoration-secondary="estado == 'deprecada'"/>
                            <field name="version_anterior_id"
                                   string="Versión anterior"/>
                            <field name="usuario_creacion_id"
                                   string="Creada por"/>
                            <field name="fecha_creacion"
                                   string="Creada"/>
                            <field name="usuario_publicacion_id"
                                   string="Publicada por"/>
                            <field name="fecha_publicacion"
                                   string="Publicada"/>
                            <button name="action_nueva_version"
                                    string="Nueva versión desde esta"
                                    type="object"
                                    icon="fa-code-fork"
                                    invisible="estado == 'borrador'"/>
                        </list>
                    </field>

                    <!-- Resumen estadístico -->
                    <group invisible="num_versiones == 0">
                        <group string="Resumen">
                            <field name="num_versiones"
                                   string="Total versiones" readonly="1"/>
                        </group>
                    </group>

                </page>
            </page>

        </field>
    </record>

</odoo>
