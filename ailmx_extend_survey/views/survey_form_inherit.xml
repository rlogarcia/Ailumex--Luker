<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- HEREDAR FORMULARIO DE INSTRUMENTOS -->
    <record id="view_survey_form_inherit_ailmx" model="ir.ui.view">
        <field name="name">survey.survey.form.ailmx</field>
        <field name="model">survey.survey</field>

        <!-- VISTA ORIGINAL-->
        <field name="inherit_id" ref="survey.survey_survey_view_form"/>
        <field name="arch" type="xml">

            <!-- 1. RENOMBRAR PESTAÑAS -->
            <xpath expr="//page[@name='questions']" position="attributes">
                <attribute name="string">Estructura</attribute>
            </xpath>
            <xpath expr="//page[@name='options']" position="attributes">
                <attribute name="string">Opciones</attribute>
            </xpath>
            <xpath expr="//page[@name='description']" position="attributes">
                <attribute name="string">Información General</attribute>
            </xpath>
            <xpath expr="//page[@name='description_done']" position="attributes">
                <attribute name="string">Mensaje final</attribute>
            </xpath>

            <!-- 2. REORDENAR PESTAÑAS EXISTENTES -->
            
            <!-- Posición 1: Mover 'Información General' antes de 'Estructura' -->
            <xpath expr="//page[@name='questions']" position="before">
                <xpath expr="//page[@name='description']" position="move"/>
            </xpath>

            <!-- 3. CREAR E INSERTAR NUEVAS PESTAÑAS (Posiciones 3 y 4) -->
            
            <!-- Insertar 'Versiones' y 'Compatibilidad' justo después de 'Estructura' -->
            <xpath expr="//page[@name='questions']" position="after">
                <page string="Versiones" name="versions">
                    <group>
                        <span class="o_form_label">Aquí irá la gestión de versiones</span>
                    </group>
                </page>
                <page string="Compatibilidad" name="compatibility">
                    <group>
                        <span class="o_form_label">Aquí irá la compatibilidad</span>
                    </group>
                </page>
            </xpath>

            <!-- 4. AJUSTAR LAS ÚLTIMAS POSICIONES (5 y 6) -->

            <!-- Posición 5: Mover 'Mensaje final' después de 'Compatibilidad' -->
            <xpath expr="//page[@name='compatibility']" position="after">
                <xpath expr="//page[@name='description_done']" position="move"/>
            </xpath>

            <!-- Posición 6: Mover 'Opciones' al final de todo -->
            <xpath expr="//notebook" position="inside">
                <xpath expr="//page[@name='options']" position="move"/>
            </xpath>


            <!-- PERSONALIZACIONES: INFORMACIÓN GENERAL -->
            <xpath expr="//page[@name='description']/field[@name='description']" position="replace">
                <group>
                    <!-- NOMBRE-->
                    <group>
                        <field name="title" string="Nombre"/>
                    </group>

                    <!-- CÓDIGO -->
                    <group>
                        <label for="id" string="Código"/>
                        <div class="o_row">
                            <field name="id" readonly="1"/>
                        </div>
                    </group>

                    <!-- DOMINIO -->
                    <!--
                    <group>
                        <field name="category_id" string="Dominio"/>
                    </group>
                    -->

                    <!-- DESCRIPCIÓN -->
                    <group col="4">
                        <field name="description" string="Descripción"/>
                    </group>

                    <!-- TIEMPO ESTIMADO (MINUTOS) -->
                    <group>
                        <field name="time_limit" string="Tiempo estimado (min)"/>
                    </group>

                    <!-- REQUIERE EVALUADOR -->
                    <group>
                        <field name="scoring_type" string="Requiere evaluador"/>
                    </group>

                    <!-- PRESENTACIÓN -->
                    <group>
                        <field name="questions_layout" string="Presentación"/>
                    </group>

                    <!-- APLICACIÓN OFFLINE -->
                    <group>
                        <field name="is_time_limited" string="Aplicación offline"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>