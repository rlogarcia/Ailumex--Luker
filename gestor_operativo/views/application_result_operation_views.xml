<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Herencia sobre luker.application.result.
        Agrega campos de la capa operativa sin modificar nada existente.
    -->
    <record id="view_application_result_operation_inherit" model="ir.ui.view">
        <field name="name">luker.application.result.form.operation.inherit</field>
        <field name="model">luker.application.result</field>
        <field name="inherit_id" ref="gestor_operativo.view_luker_application_result_form"/>
        <field name="arch" type="xml">

            <!-- Smart button: Snapshot -->
            <div name="button_box" position="inside">
                <button name="%(gestor_operativo.action_luker_application_result)d"
                        type="action"
                        class="oe_stat_button"
                        icon="fa-camera"
                        invisible="not snapshot_id">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Snapshot</span>
                    </div>
                </button>
            </div>

            <!-- Banda de sync status -->
            <xpath expr="//sheet" position="before">
                <div class="alert alert-warning d-flex gap-2"
                     invisible="sync_status not in ('queued','syncing','conflict','error')">
                    <i class="fa fa-refresh mt-1"/>
                    <div>
                        <strong>Sync:</strong>
                        <field name="sync_status" widget="badge"
                               decoration-warning="sync_status in ('queued','syncing')"
                               decoration-danger="sync_status in ('conflict','error')"
                               nolabel="1"/>
                    </div>
                </div>
            </xpath>

            <!-- Pestaña Contexto Operativo -->
            <xpath expr="//notebook" position="inside">
                <page string="Contexto operativo" name="operativo">
                    <group>
                        <group string="Campaña y tarea">
                            <field name="campana_id" readonly="1"/>
                            <field name="task_id" readonly="1"/>
                            <field name="executor_id" readonly="1"/>
                        </group>
                        <group string="Offline / Sync">
                            <field name="uuid_local" readonly="1"/>
                            <field name="sync_status" widget="badge"
                                   decoration-success="sync_status == 'synced'"
                                   decoration-warning="sync_status in ('queued','draft')"
                                   decoration-danger="sync_status in ('conflict','error')"/>
                            <field name="dispositivo_id" readonly="1"/>
                            <field name="fecha_inicio_dispositivo" readonly="1"/>
                            <field name="fecha_fin_dispositivo" readonly="1"/>
                        </group>
                    </group>
                    <group string="Estado de captura">
                        <field name="estado_sesion" widget="statusbar"
                               statusbar_visible="iniciada,en_pausa,completada"/>
                        <field name="pregunta_actual" readonly="1" string="Última pregunta guardada"/>
                    </group>
                    <group string="Snapshot de contexto" invisible="not snapshot_id">
                        <field name="snapshot_id" readonly="1" nolabel="1"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>
</odoo>
