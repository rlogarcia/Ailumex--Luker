<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
  <data>
    <record id="seq_luker_participant" model="ir.sequence">
      <field name="name">Luker Participant Reference</field>
      <field name="code">luker.participant</field>
      <field name="prefix">LUK-</field>
      <field name="padding">6</field>
      <field name="number_next">1</field>
      <field name="number_increment">1</field>
    </record>

    <record id="participant_type_estudiante" model="luker.participant.type">
      <field name="cod_tipo_participante">estudiante</field>
      <field name="nom_tipo_participante">Estudiante</field>
      <field name="orden">10</field>
      <field name="descripcion">Participante en proceso de formación educativa formal o informal.</field>
    </record>
    <record id="participant_type_empleado" model="luker.participant.type">
      <field name="cod_tipo_participante">empleado</field>
      <field name="nom_tipo_participante">Empleado</field>
      <field name="orden">20</field>
    </record>
    <record id="participant_type_docente" model="luker.participant.type">
      <field name="cod_tipo_participante">docente</field>
      <field name="nom_tipo_participante">Docente</field>
      <field name="orden">30</field>
    </record>
    <record id="participant_type_directivo" model="luker.participant.type">
      <field name="cod_tipo_participante">directivo_docente</field>
      <field name="nom_tipo_participante">Directivo Docente</field>
      <field name="orden">40</field>
    </record>
    <record id="participant_type_acudiente" model="luker.participant.type">
      <field name="cod_tipo_participante">acudiente</field>
      <field name="nom_tipo_participante">Acudiente / Padre de Familia</field>
      <field name="orden">50</field>
    </record>
    <record id="participant_type_comunidad" model="luker.participant.type">
      <field name="cod_tipo_participante">comunidad</field>
      <field name="nom_tipo_participante">Miembro de Comunidad</field>
      <field name="orden">60</field>
    </record>
  </data>
</odoo>
