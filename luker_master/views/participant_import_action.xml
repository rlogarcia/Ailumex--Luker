<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Acción de ventana para lanzar el wizard de carga masiva.
        Se define aquí separado del wizard para garantizar que
        el modelo luker.participant ya esté cargado antes.
    -->
    <record id="action_luker_participant_import_wizard" model="ir.actions.act_window">
        <field name="name">Carga Masiva de Participantes</field>
        <field name="res_model">luker.participant.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!--
        Acción de servidor vinculada al modelo luker.participant.
        Aparece en el menú ⚙ Acciones de la lista de participantes.
        NOTA: Los campos state y code son de ir.actions.server (Odoo),
        NO son campos del modelo de datos — no se renombran.
    -->
    <record id="action_server_import_participants" model="ir.actions.server">
        <field name="name">📥 Carga Masiva (SIMAT / Excel)</field>
        <field name="model_id" ref="model_luker_participant"/>
        <field name="binding_model_id" ref="model_luker_participant"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">
action = {
    'type': 'ir.actions.act_window',
    'name': 'Carga Masiva de Participantes',
    'res_model': 'luker.participant.import.wizard',
    'view_mode': 'form',
    'target': 'new',
}
        </field>
    </record>

</odoo>
