<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══ SEARCH ══ -->
    <record id="view_luker_participant_search" model="ir.ui.view">
        <field name="name">luker.participant.search</field>
        <field name="model">luker.participant</field>
        <field name="arch" type="xml">
            <search string="Buscar Participantes — PAR_Participante">
                <field name="nom_completo" string="Nombre"/>
                <field name="cod_participante" string="Código"/>
                <field name="partner_id" string="Contacto"/>
                <field name="identidad_principal_display" string="Identificación"/>
                <field name="tipo_participante_id" string="Tipo"/>
                <field name="institucion_actual_id" string="Institución"/>
                <separator/>
                <filter name="activos"   string="Activos"   domain="[('estado','=','activo')]"/>
                <filter name="inactivos" string="Inactivos" domain="[('estado','=','inactivo')]"/>
                <filter name="sync_error" string="Error sync" domain="[('estado_sync','=','error_sync')]"/>
                <separator/>
                <group expand="0" string="Agrupar por">
                    <filter name="g_tipo"  string="Tipo"         context="{'group_by':'tipo_participante_id'}"/>
                    <filter name="g_inst"  string="Institución"  context="{'group_by':'institucion_actual_id'}"/>
                    <filter name="g_estado" string="Estado"      context="{'group_by':'estado'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══ LIST ══ -->
    <record id="view_luker_participant_list" model="ir.ui.view">
        <field name="name">luker.participant.list</field>
        <field name="model">luker.participant</field>
        <field name="arch" type="xml">
            <list string="Participantes — PAR_Participante"
                  decoration-muted="estado == 'inactivo'"
                  decoration-danger="estado_sync in ('error_sync','conflicto')">
                <header>
                    <button string="📥 Carga Masiva"
                            name="action_open_import_wizard"
                            type="object" class="btn-primary"/>
                </header>
                <field name="image_128" widget="image" optional="show" class="o_image_32_max"/>
                <field name="cod_participante" string="Código" optional="show" width="100"/>
                <field name="nom_completo" string="Nombre Completo"/>
                <field name="tipo_participante_id" widget="badge" decoration-info="True" string="Tipo"/>
                <field name="identidad_principal_display" string="Identificación" optional="show"/>
                <field name="institucion_actual_id" string="Institución" optional="show"/>
                <field name="unidad_actual_id" string="Unidad" optional="show"/>
                <field name="estado" widget="badge"
                       decoration-success="estado == 'activo'"
                       decoration-warning="estado == 'borrador'"
                       decoration-muted="estado in ('inactivo','archivado')"/>
                <field name="estado_sync" widget="badge"
                       decoration-success="estado_sync == 'sincronizado'"
                       decoration-warning="estado_sync in ('en_cola','borrador_local')"
                       decoration-danger="estado_sync in ('error_sync','conflicto')"
                       optional="show"/>
                <field name="sesion_count" string="Aplicaciones" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ══ KANBAN ══ -->
    <record id="view_luker_participant_kanban" model="ir.ui.view">
        <field name="name">luker.participant.kanban</field>
        <field name="model">luker.participant</field>
        <field name="arch" type="xml">
            <kanban records_draggable="false">
                <field name="nom_completo"/>
                <field name="cod_participante"/>
                <field name="tipo_participante_id"/>
                <field name="estado"/>
                <field name="estado_sync"/>
                <field name="identidad_principal_display"/>
                <field name="institucion_actual_id"/>
                <field name="sesion_count"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="d-flex align-items-start gap-2 mb-2">
                                <img t-att-src="kanban_image('luker.participant','image_128',record.id.raw_value)"
                                     class="rounded-circle" style="width:40px;height:40px;object-fit:cover;"/>
                                <div class="flex-grow-1">
                                    <strong><field name="nom_completo"/></strong>
                                    <div class="text-muted small"><field name="cod_participante"/></div>
                                </div>
                                <field name="estado" widget="badge"
                                       decoration-success="estado == 'activo'"
                                       decoration-muted="estado == 'inactivo'"/>
                            </div>
                            <div class="small text-muted">
                                <i class="fa fa-id-card me-1"/><field name="identidad_principal_display"/>
                            </div>
                            <div class="small text-muted">
                                <i class="fa fa-building me-1"/><field name="institucion_actual_id"/>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <field name="tipo_participante_id" widget="badge" decoration-info="True"/>
                                <span class="text-muted small">
                                    <i class="fa fa-file-text-o me-1"/>
                                    <field name="sesion_count"/> apps
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ══ FORM ══ -->
    <record id="view_luker_participant_form" model="ir.ui.view">
        <field name="name">luker.participant.form</field>
        <field name="model">luker.participant</field>
        <field name="arch" type="xml">
            <form string="Participante — PAR_Participante">
                <header>
                    <button name="action_set_activo" string="Activar" type="object"
                            class="btn-primary" invisible="estado == 'activo'"/>
                    <button name="action_set_inactivo" string="Desactivar" type="object"
                            invisible="estado != 'activo'"/>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="borrador,activo,inactivo"/>
                </header>
                <sheet>
                    <div class="alert alert-warning mb-0"
                         invisible="estado_sync not in ('error_sync','conflicto')">
                        <i class="fa fa-exclamation-triangle me-2"/>
                        <strong>Problema de sincronización:</strong>
                        <field name="estado_sync" readonly="1"/> —
                        Dispositivo: <field name="dispositivo_id" readonly="1"/>
                    </div>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_ver_sesiones" type="object"
                                class="oe_stat_button" icon="fa-file-text-o">
                            <field name="sesion_count" widget="statinfo" string="Aplicaciones"/>
                        </button>
                        <button name="action_abrir_contacto" type="object"
                                class="oe_stat_button" icon="fa-user-circle">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Ver Contacto</span>
                            </div>
                        </button>
                        <button class="oe_stat_button" icon="fa-id-card">
                            <field name="identidad_count" widget="statinfo" string="Identidades"/>
                        </button>
                    </div>

                    <widget name="web_ribbon" title="Inactivo"
                            invisible="estado != 'inactivo'" bg_color="bg-warning"/>

                    <div class="oe_title d-flex align-items-center gap-3">
                        <field name="image_128" widget="image" class="rounded-circle"
                               style="width:72px;height:72px;object-fit:cover;"/>
                        <div>
                            <h1 class="mb-0"><field name="nom_completo" readonly="1"/></h1>
                            <div class="text-muted">
                                <field name="cod_participante" readonly="1" class="fw-bold text-primary"/>
                                · uuid: <field name="uuid_local" readonly="1"/>
                            </div>
                            <div class="mt-1">
                                <field name="estado_sync" widget="badge"
                                       decoration-success="estado_sync == 'sincronizado'"
                                       decoration-warning="estado_sync in ('en_cola','borrador_local')"
                                       decoration-danger="estado_sync in ('error_sync','conflicto')"/>
                            </div>
                        </div>
                    </div>

                    <group>
                        <group string="Clasificación — PAR_Participante">
                            <field name="tipo_participante_id" options="{'no_create': True}"
                                   string="Tipo de Participante (Id_PAR_Tipo_Participante)"/>
                            <field name="fuente_creacion" string="Fuente de Creación"/>
                        </group>
                        <group string="Sincronización">
                            <field name="fecha_ultima_sync" readonly="1"/>
                            <field name="dispositivo_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ── Tab 1: Datos del Contacto ── -->
                        <page string="Datos del Contacto" name="contacto">
                            <div class="alert alert-info">
                                <i class="fa fa-info-circle me-2"/>
                                Los datos personales se toman del módulo de <strong>Contactos</strong>.
                                Para editarlos usa el botón "Ver Contacto".
                            </div>
                            <group>
                                <group string="Contacto vinculado">
                                    <field name="partner_id" options="{'no_create': False}"
                                           domain="[('is_company','=',False)]"
                                           string="Contacto (res.partner)"/>
                                </group>
                                <group string="Datos del contacto (solo lectura)">
                                    <field name="email" readonly="1"/>
                                    <field name="telefono" readonly="1"/>
                                </group>
                            </group>
                            <group string="Datos propios del participante — PAR_Participante">
                                <group>
                                    <field name="fecha_nacimiento" string="Fecha Nacimiento (Fecha_Nacimiento)"/>
                                    <field name="edad" readonly="1"/>
                                </group>
                                <group>
                                    <field name="sexo" string="Sexo (Sexo)"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Tab 2: Identidades — PAR_Identidad ── -->
                        <page string="Identidades — PAR_Identidad" name="identidades">
                            <field name="identidad_ids" context="{'default_participante_id': id}">
                                <list editable="bottom"
                                      decoration-primary="es_principal and estado == 'activa'">
                                    <field name="tipo_identidad_id"
                                           string="Tipo de Identidad (Id_PAR_Tipo_Identidad)"
                                           options="{'no_create': True}"/>
                                    <field name="num_identidad" string="Número (Num_Identidad)"/>
                                    <field name="es_principal" widget="boolean_toggle"
                                           string="Es Principal"/>
                                    <field name="vigencia_desde" string="Vigencia Desde"/>
                                    <field name="vigencia_hasta" string="Vigencia Hasta"/>
                                    <field name="estado" widget="badge"
                                           decoration-success="estado == 'activa'"
                                           decoration-muted="estado != 'activa'"
                                           string="Estado"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Tab 3: Contexto — PAR_Asignacion_Contexto ── -->
                        <page string="Contexto — PAR_Asignacion_Contexto" name="contexto">
                            <group>
                                <group string="Contexto actual (calculado)">
                                    <field name="institucion_actual_id" readonly="1"
                                           string="Institución actual"/>
                                    <field name="unidad_actual_id" readonly="1"
                                           string="Unidad actual"/>
                                </group>
                            </group>
                            <separator string="Histórico de Asignaciones"/>
                            <field name="asignacion_contexto_ids" context="{'default_participante_id': id}">
                                <list editable="bottom" decoration-success="es_actual">
                                    <field name="institucion_id" string="Institución (Id_CTX_Institucion)"/>
                                    <field name="sede_id" string="Sede (Id_CTX_Sede)"
                                           options="{'no_create': True}"/>
                                    <field name="unidad_id" string="Grado/Grupo (Id_CTX_Grado/Grupo)"
                                           options="{'no_create': True}"/>
                                    <field name="vigencia_desde" string="Vigencia Desde"/>
                                    <field name="vigencia_hasta" string="Vigencia Hasta"/>
                                    <field name="es_actual" readonly="1" widget="boolean_toggle"
                                           string="Es Actual"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Tab 4: Caracterización — PAR_Valor_Dinamico ── -->
                        <page string="Caracterización — PAR_Valor_Dinamico" name="caracterizacion">
                            <field name="valor_dinamico_ids" context="{'default_participante_id': id}">
                                <list editable="bottom" decoration-muted="not es_vigente">
                                    <field name="definicion_id" string="Atributo (Id_ATR_Definicion)"
                                           options="{'no_create': True}"/>
                                    <field name="tipo_dato" readonly="1" optional="hide"
                                           string="Tipo Dato"/>
                                    <field name="valor_display" string="Valor" readonly="1"/>
                                    <field name="valor_texto"    invisible="tipo_dato not in ('char','text')"/>
                                    <field name="valor_numero"   invisible="tipo_dato not in ('integer','float')"/>
                                    <field name="valor_booleano" widget="boolean_toggle"
                                                                 invisible="tipo_dato != 'boolean'"/>
                                    <field name="valor_fecha"    invisible="tipo_dato != 'date'"/>
                                    <field name="opcion_id"      invisible="tipo_dato != 'selection'"/>
                                    <field name="vigencia_desde" string="Vigencia Desde"/>
                                    <field name="vigencia_hasta" string="Vigencia Hasta"/>
                                    <field name="es_vigente" readonly="1" widget="boolean_toggle"
                                           string="Es Vigente"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Tab 5: Aplicaciones — APP_Sesion ── -->
                        <page string="Aplicaciones — APP_Sesion" name="aplicaciones">
                            <field name="sesion_ids" readonly="1">
                                <list decoration-success="puntaje_normalizado >= 80"
                                      decoration-warning="puntaje_normalizado >= 60 and puntaje_normalizado &lt; 80"
                                      decoration-danger="puntaje_normalizado &lt; 60 and puntaje_normalizado > 0">
                                    <field name="survey_id" string="Encuesta / Instrumento"/>
                                    <field name="fecha_hora_inicio_dispositivo" string="Fecha"/>
                                    <field name="snapshot_grado_grupo" string="Contexto" optional="show"/>
                                    <field name="puntaje_normalizado" string="Puntaje %"/>
                                    <field name="cod_nivel" widget="badge"
                                           decoration-success="cod_nivel == 'avanzado'"
                                           decoration-info="cod_nivel == 'medio'"
                                           decoration-warning="cod_nivel == 'basico'"
                                           decoration-danger="cod_nivel == 'inicial'"/>
                                    <field name="estado_sesion" widget="badge"
                                           decoration-success="estado_sesion == 'sincronizada'"
                                           decoration-danger="estado_sesion in ('error_sync','conflicto')"/>
                                    <field name="tiene_audio" widget="boolean" string="🎙" optional="show"/>
                                </list>
                            </field>
                        </page>

                        <!-- ── Tab 6: Notas ── -->
                        <page string="Notas" name="notas">
                            <field name="notas" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══ ACTION ══ -->
    <record id="action_luker_participant" model="ir.actions.act_window">
        <field name="name">Participantes — PAR_Participante</field>
        <field name="res_model">luker.participant</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_luker_participant_search"/>
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay participantes registrados.</p>
            <p>Crea el primer participante o usa la Carga Masiva para importar desde SIMAT.</p>
        </field>
    </record>

</odoo>
