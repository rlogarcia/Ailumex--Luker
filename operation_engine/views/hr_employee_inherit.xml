<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Herencia sobre hr.employee usando xpath genérico.
        Agrega pestaña SISPAR y smart button al formulario del empleado.
    -->

    <record id="view_hr_employee_sispar_inherit_v2" model="ir.ui.view">
        <field name="name">hr.employee.form.sispar.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Smart button SISPAR en el button_box -->
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button name="action_registrar_como_ejecutor"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-user-circle">
                    <div class="o_stat_info">
                        <span class="o_stat_text"
                              invisible="es_ejecutor_sispar">
                            Registrar en SISPAR
                        </span>
                        <span class="o_stat_text"
                              invisible="not es_ejecutor_sispar">
                            Ejecutor SISPAR
                        </span>
                    </div>
                </button>
            </xpath>

            <!-- Pestaña SISPAR al final del notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="SISPAR" name="sispar_page">

                    <div invisible="not es_ejecutor_sispar">
                        <div class="alert alert-success d-flex gap-2 mb-3">
                            <i class="fa fa-check-circle mt-1"/>
                            <span>Este empleado está registrado como ejecutor SISPAR.</span>
                        </div>
                        <field name="executor_sispar_id" nolabel="1" readonly="1">
                            <list string="Rol SISPAR">
                                <field name="cod_ejecutor" string="Código"/>
                                <field name="rol" widget="badge"
                                       decoration-info="rol == 'aplicador'"
                                       decoration-warning="rol == 'supervisor'"
                                       decoration-success="rol == 'coordinador'"/>
                                <field name="tarea_count" string="Tareas"/>
                                <field name="tarea_completada_count" string="Completadas"/>
                                <field name="activo"/>
                            </list>
                        </field>
                    </div>

                    <div invisible="es_ejecutor_sispar">
                        <div class="alert alert-info d-flex gap-2">
                            <i class="fa fa-info-circle mt-1"/>
                            <div>
                                Este empleado no está registrado como ejecutor SISPAR.
                                Usa el botón del encabezado para registrarlo.
                            </div>
                        </div>
                    </div>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
