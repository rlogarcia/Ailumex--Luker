<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Secuencia para instrumentos -->
        <record id="sequence_survey_instrument" model="ir.sequence">
            <field name="name">Secuencia de Instrumentos</field>
            <field name="code">survey.survey.instrument</field>
            <field name="prefix">INS-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next_actual">1</field>
        </record>

        <!-- Secuencia global para versiones de instrumentos -->
        <record id="sequence_instrument_version" model="ir.sequence">
            <field name="name">Secuencia de Versiones de Instrumentos</field>
            <field name="code">luker.instrument.version</field>
            <field name="prefix">VER-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="number_next_actual">1</field>
        </record>

    </data>
</odoo>
